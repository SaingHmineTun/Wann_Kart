<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FF"
    android:padding="20dp"
    tools:context=".MainActivity">

    <RelativeLayout
        android:id="@+id/headerSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/tvDay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="25"
            android:fontFamily="sans-serif-black"
            android:textColor="#1A1C1E"
            android:textSize="90sp"
            android:letterSpacing="-0.05"
            android:includeFontPadding="false" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/tvDay"
            android:layout_alignTop="@id/tvDay"
            android:layout_marginTop="12dp"
            android:layout_marginStart="8dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="သောကြာ"
                android:textSize="20sp"
                android:textColor="#0067FF" />

            <TextView
                android:id="@+id/tvMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="June 2022"
                android:textSize="16sp"
                android:textColor="#74777F"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/myanmarDateCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvDay"
            android:layout_marginTop="-10dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E0E2EC"
            app:cardBackgroundColor="#FFFFFF">

            <TextView
                android:id="@+id/tvMyanmarDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:text="၁၃၈၄ ခု၊ နယုန်လဆန်း ၇ ရက်"
                android:textColor="#44474E"
                android:drawableStart="@drawable/ic_calendar_mini"
                android:drawablePadding="8dp"
                android:textSize="14sp" />
        </com.google.android.material.card.MaterialCardView>
    </RelativeLayout>

    <GridLayout
        android:id="@+id/headerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/headerSection"
        android:columnCount="7"
        android:layout_marginBottom="12dp">

        <TextView android:layout_columnWeight="1" android:gravity="center" android:text="S" android:textColor="#FF5252" android:textSize="12sp" android:fontFamily="sans-serif-black" />
        <TextView android:layout_columnWeight="1" android:gravity="center" android:text="M" android:textColor="#9DA3A9" android:textSize="12sp" />
        <TextView android:layout_columnWeight="1" android:gravity="center" android:text="T" android:textColor="#9DA3A9" android:textSize="12sp" />
        <TextView android:layout_columnWeight="1" android:gravity="center" android:text="W" android:textColor="#9DA3A9" android:textSize="12sp" />
        <TextView android:layout_columnWeight="1" android:gravity="center" android:text="T" android:textColor="#9DA3A9" android:textSize="12sp" />
        <TextView android:layout_columnWeight="1" android:gravity="center" android:text="F" android:textColor="#9DA3A9" android:textSize="12sp" />
        <TextView android:layout_columnWeight="1" android:gravity="center" android:text="S" android:textColor="#FF5252" android:textSize="12sp" android:fontFamily="sans-serif-black" />
    </GridLayout>

    <GridLayout
        android:id="@+id/calenderPane"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/layout2"
        android:layout_below="@id/headerView"
        android:columnCount="7" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layout2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#1A1C1E">

        <TextView
            android:id="@+id/tvWannKart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="10dp"
            android:text="မူဆယ်ဈေးနေ့"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:letterSpacing="0.05" />
    </com.google.android.material.card.MaterialCardView>

</RelativeLayout>