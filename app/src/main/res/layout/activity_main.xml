<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FF"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:menu="@menu/menu_main"
            app:title="Wann Kart (ဈေးနေ့)"
            app:titleTextColor="#1A1C1E" />
    </com.google.android.material.appbar.AppBarLayout>

    <RelativeLayout
        android:id="@+id/headerSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/appBar"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/tvDay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:includeFontPadding="false"
            android:letterSpacing="-0.05"
            android:text="25"
            android:textColor="#1A1C1E"
            android:textSize="90sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignTop="@id/tvDay"
            android:layout_marginStart="12dp"
            android:layout_marginTop="16dp"
            android:layout_toEndOf="@id/tvDay"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="သောကြာ"
                android:textColor="#0067FF"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/tvMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.1"
                android:text="June 2022"
                android:textAllCaps="true"
                android:textColor="#74777F"
                android:textSize="14sp" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/myanmarDateCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvDay"
            android:layout_marginTop="-12dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:strokeColor="#E0E2EC"
            app:strokeWidth="1dp">

            <TextView
                android:id="@+id/tvMyanmarDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_calendar_mini"
                android:drawablePadding="12dp"
                android:paddingHorizontal="20dp"
                android:paddingVertical="14dp"
                android:text="၁၃၈၄ ခု၊ နယုန်လဆန်း ၇ ရက်"
                android:textColor="#44474E"
                android:textSize="14sp" />
        </com.google.android.material.card.MaterialCardView>
    </RelativeLayout>

    <GridLayout
        android:id="@+id/headerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/headerSection"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="12dp"
        android:columnCount="7">

        <TextView android:layout_columnWeight="1" android:gravity="center" android:text="S" android:textColor="#FF5252" android:textSize="12sp" android:fontFamily="sans-serif-black" />
        <TextView android:layout_columnWeight="1" android:gravity="center" android:text="M" android:textColor="#9DA3A9" android:textSize="12sp" />
        <TextView android:layout_columnWeight="1" android:gravity="center" android:text="T" android:textColor="#9DA3A9" android:textSize="12sp" />
        <TextView android:layout_columnWeight="1" android:gravity="center" android:text="W" android:textColor="#9DA3A9" android:textSize="12sp" />
        <TextView android:layout_columnWeight="1" android:gravity="center" android:text="T" android:textColor="#9DA3A9" android:textSize="12sp" />
        <TextView android:layout_columnWeight="1" android:gravity="center" android:text="F" android:textColor="#9DA3A9" android:textSize="12sp" />
        <TextView android:layout_columnWeight="1" android:gravity="center" android:text="S" android:textColor="#FF5252" android:textSize="12sp" android:fontFamily="sans-serif-black" />
    </GridLayout>

    <GridLayout
        android:id="@+id/calenderPane"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/layout2"
        android:layout_below="@id/headerView"
        android:layout_marginHorizontal="20dp"
        android:columnCount="7" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layout2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="#1A1C1E"
        app:cardCornerRadius="32dp"
        app:cardElevation="8dp">

        <TextView
            android:id="@+id/tvWannKart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="16dp"
            android:text="မူဆယ်ဈေးနေ့"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-medium"
            android:textSize="18sp" />
    </com.google.android.material.card.MaterialCardView>

</RelativeLayout>